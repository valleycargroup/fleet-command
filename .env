# Database — local Docker values, make these whatever you want
DB_USER=fleetuser
DB_PASSWORD=fleetpass123
DB_NAME=fleet_command
DB_HOST=db
DB_PORT=5434
DATABASE_URL=postgresql://fleetuser:fleetpass123@db:5432/fleet_command

# Server
SERVER_PORT=5002
CLIENT_PORT=4002

# Client
VITE_API_BASE_URL=http://localhost:5002
VITE_APP_URL=http://localhost:4002

# Email (Resend) — get your key at resend.com/api-keys
RESEND_API_KEY=re_your_key_here
FROM_EMAIL=Fleet Command <notifications@fleetcommandrecon.com>
APP_URL=http://localhost:4002
