# Database
DB_USER=fleetuser
DB_PASSWORD=changeme
DB_NAME=fleet_command
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://fleetuser:changeme@db:5432/fleet_command

# Server
SERVER_PORT=5001
CLIENT_PORT=3000

# Client
VITE_API_BASE_URL=http://localhost:5001

# Storage (S3) — leave blank for local file fallback during dev
# S3_REGION=us-east-2
# S3_IMAGE_BUCKET=dev-fleet-command-images
# S3_FILES_BUCKET=dev-fleet-command-files
# S3_IMAGE_PUBLIC_BASE_URL=https://your-cloudfront-domain.cloudfront.net
# S3_FILES_PUBLIC_BASE_URL=https://your-cloudfront-domain.cloudfront.net
# S3_ACCESS_KEY_ID=              # omit on EC2 — uses instance role automatically
# S3_SECRET_ACCESS_KEY=          # omit on EC2 — uses instance role automatically
#
# Local dev with LocalStack (both Fleet and Auction in Docker):
# S3_ENDPOINT=http://localstack:4566          # internal endpoint for uploads
# S3_FORCE_PATH_STYLE=true                    # required for LocalStack
# S3_IMAGE_PUBLIC_BASE_URL=http://host.docker.internal:4566/dev-fleet-command-images
#   ^ host.docker.internal lets the Auction container download photos from LocalStack on the host
#
# Local dev with file storage (no S3) + both apps in Docker:
# SERVER_PUBLIC_URL=http://host.docker.internal:5001
#   ^ without this, photo URLs use localhost:5001 which the Auction container can't reach

# Email (SendGrid) — get your key at sendgrid.com
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=notifications@fleetcommandrecon.net
SENDGRID_FROM_NAME=Fleet Command
APP_URL=http://localhost:3000

# Auction + CRM integrations (apps/server/src/lib/integrationConfig.ts)
# Base URLs are hardcoded per environment (local/dev/prod) in code.
# API keys: read from AWS SSM Parameter Store once deployed — only needed
# here for local dev, since laptops have no AWS access.
FLEET_COMMAND_API_KEY=8cBKglvkhXEmiK2nR4dfTULSFAeuy8
# must match the FLEET_COMMAND_API_KEY configured in the Auction app
# (deployed: read from /prod/fleet-command/fleet-command-api-key)
CRM_FLEET_COMMAND_API_KEY=JpbcpTZU58gpKfQxRn6Y7ZZdjucroK
# must match CRM's own SSM parameter /prod/external/fleet-command/api-key
# (Fleet reads that same parameter directly once deployed — no separate copy)
# CRM_LOCAL_HOST=192.168.x.x
# only needed locally if host.docker.internal collides with CRM's debugger
# (see comment in integrationConfig.ts) — set to your machine's LAN IP

# Test data (set TEST_DATA_PROFILE=minimal for a smaller seed set)
# TEST_ADMIN_USERNAME=admin
# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PHONE=15555550001
# TEST_USER_USERNAME=user
# TEST_USER_EMAIL=user@example.com
# TEST_USER_PHONE=15555550002
# TEST_DATA_PROFILE=minimal
# SEED_DATA=1

curl -X POST http://localhost:5002/api/auth/change-password \
  -H "Authorization: Bearer <your-token>" \
  -H "Content-Type: application/json" \
  -d '{"new_password": "password123"}'
